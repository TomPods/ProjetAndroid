<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/calc_bg">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="4dp">

        <ImageView
            android:id="@+id/bouton_retour"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_arrow_back"
            android:scaleType="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Retour"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/nav_calculatrice"
            android:textSize="13sp"
            android:textColor="@color/calc_header_text"
            android:gravity="center"
            android:fontFamily="sans-serif-light"
            android:letterSpacing="0.15"/>

        <View
            android:layout_width="48dp"
            android:layout_height="48dp"/>

    </LinearLayout>

    <!-- Display area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:background="@color/calc_display_bg"
        android:orientation="vertical"
        android:gravity="bottom|end"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingBottom="24dp"
        android:paddingTop="12dp">

        <TextView
            android:id="@+id/textView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:hint="0"
            android:textColorHint="@color/calc_display_hint"
            android:textColor="@color/calc_display_text"
            android:textSize="52sp"
            android:fontFamily="sans-serif-thin"
            android:maxLines="1"
            android:ellipsize="start"/>

    </LinearLayout>

    <!-- Separator -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/calc_divider"/>

    <!-- Button grid -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="5"
        android:orientation="vertical"
        android:padding="10dp">

        <!-- Row 1: C (×2), ⌫, ÷ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <Button
                android:id="@+id/button_c"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="2"
                android:layout_margin="5dp"
                android:text="C"
                android:textSize="20sp"
                android:textColor="@color/calc_btn_function_text"
                android:background="@drawable/bg_btn_function"
                android:stateListAnimator="@null"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:fontFamily="sans-serif-medium"/>

            <Button
                android:id="@+id/button_effacer"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:text="⌫"
                android:textSize="20sp"
                android:textColor="@color/calc_btn_function_text"
                android:background="@drawable/bg_btn_function"
                android:stateListAnimator="@null"
                android:minHeight="0dp"
                android:minWidth="0dp"/>

            <Button
                android:id="@+id/button_diviser"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:text="÷"
                android:textSize="26sp"
                android:textColor="@color/calc_btn_operator_text"
                android:background="@drawable/bg_btn_operator"
                android:stateListAnimator="@null"
                android:minHeight="0dp"
                android:minWidth="0dp"/>

        </LinearLayout>

        <!-- Row 2: 7, 8, 9, × -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <Button
                android:id="@+id/button_7"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:text="7"
                android:textSize="22sp"
                android:textColor="@color/calc_btn_number_text"
                android:background="@drawable/bg_btn_number"
                android:stateListAnimator="@null"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:fontFamily="sans-serif-light"/>

            <Button
                android:id="@+id/button_8"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:text="8"
                android:textSize="22sp"
                android:textColor="@color/calc_btn_number_text"
                android:background="@drawable/bg_btn_number"
                android:stateListAnimator="@null"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:fontFamily="sans-serif-light"/>

            <Button
                android:id="@+id/button_9"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:text="9"
                android:textSize="22sp"
                android:textColor="@color/calc_btn_number_text"
                android:background="@drawable/bg_btn_number"
                android:stateListAnimator="@null"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:fontFamily="sans-serif-light"/>

            <Button
                android:id="@+id/button_multiplier"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:text="×"
                android:textSize="26sp"
                android:textColor="@color/calc_btn_operator_text"
                android:background="@drawable/bg_btn_operator"
                android:stateListAnimator="@null"
                android:minHeight="0dp"
                android:minWidth="0dp"/>

        </LinearLayout>

        <!-- Row 3: 4, 5, 6, - -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <Button
                android:id="@+id/button_4"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:text="4"
                android:textSize="22sp"
                android:textColor="@color/calc_btn_number_text"
                android:background="@drawable/bg_btn_number"
                android:stateListAnimator="@null"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:fontFamily="sans-serif-light"/>

            <Button
                android:id="@+id/button_5"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:text="5"
                android:textSize="22sp"
                android:textColor="@color/calc_btn_number_text"
                android:background="@drawable/bg_btn_number"
                android:stateListAnimator="@null"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:fontFamily="sans-serif-light"/>

            <Button
                android:id="@+id/button_6"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:text="6"
                android:textSize="22sp"
                android:textColor="@color/calc_btn_number_text"
                android:background="@drawable/bg_btn_number"
                android:stateListAnimator="@null"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:fontFamily="sans-serif-light"/>

            <Button
                android:id="@+id/button_moins"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:text="−"
                android:textSize="28sp"
                android:textColor="@color/calc_btn_operator_text"
                android:background="@drawable/bg_btn_operator"
                android:stateListAnimator="@null"
                android:minHeight="0dp"
                android:minWidth="0dp"/>

        </LinearLayout>

        <!-- Row 4: 1, 2, 3, + -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <Button
                android:id="@+id/button_1"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:text="1"
                android:textSize="22sp"
                android:textColor="@color/calc_btn_number_text"
                android:background="@drawable/bg_btn_number"
                android:stateListAnimator="@null"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:fontFamily="sans-serif-light"/>

            <Button
                android:id="@+id/button_2"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:text="2"
                android:textSize="22sp"
                android:textColor="@color/calc_btn_number_text"
                android:background="@drawable/bg_btn_number"
                android:stateListAnimator="@null"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:fontFamily="sans-serif-light"/>

            <Button
                android:id="@+id/button_3"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:text="3"
                android:textSize="22sp"
                android:textColor="@color/calc_btn_number_text"
                android:background="@drawable/bg_btn_number"
                android:stateListAnimator="@null"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:fontFamily="sans-serif-light"/>

            <Button
                android:id="@+id/button_plus"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:text="+"
                android:textSize="28sp"
                android:textColor="@color/calc_btn_operator_text"
                android:background="@drawable/bg_btn_operator"
                android:stateListAnimator="@null"
                android:minHeight="0dp"
                android:minWidth="0dp"/>

        </LinearLayout>

        <!-- Row 5: 0 (×2), ., = -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <Button
                android:id="@+id/button_0"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="2"
                android:layout_margin="5dp"
                android:text="0"
                android:textSize="22sp"
                android:textColor="@color/calc_btn_number_text"
                android:background="@drawable/bg_btn_number"
                android:stateListAnimator="@null"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:fontFamily="sans-serif-light"/>

            <Button
                android:id="@+id/button_virgule"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:text="."
                android:textSize="28sp"
                android:textColor="@color/calc_btn_number_text"
                android:background="@drawable/bg_btn_number"
                android:stateListAnimator="@null"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:fontFamily="sans-serif-medium"/>

            <Button
                android:id="@+id/button_egal"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:text="="
                android:textSize="26sp"
                android:textColor="@color/calc_btn_operator_text"
                android:background="@drawable/bg_btn_operator"
                android:stateListAnimator="@null"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:fontFamily="sans-serif-medium"/>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
