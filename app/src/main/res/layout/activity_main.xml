<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/calc_bg">

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- Branding -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingBottom="52dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="APPLI"
            android:textSize="48sp"
            android:textColor="@color/calc_accent"
            android:fontFamily="sans-serif-thin"
            android:letterSpacing="0.25"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Android"
            android:textSize="14sp"
            android:textColor="@color/calc_header_text"
            android:fontFamily="sans-serif-light"
            android:letterSpacing="0.12"/>

    </LinearLayout>

    <!-- Menu buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingEnd="28dp">

        <Button
            android:id="@+id/bouton_calculatrice"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="@string/text_bouton_calculatrice"
            android:textSize="16sp"
            android:textColor="@color/calc_btn_operator_text"
            android:background="@drawable/bg_btn_operator"
            android:stateListAnimator="@null"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.05"/>

        <View android:layout_width="match_parent" android:layout_height="14dp"/>

        <Button
            android:id="@+id/bouton_jeu"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="@string/text_bouton_jeu"
            android:textSize="16sp"
            android:textColor="@color/calc_btn_number_text"
            android:background="@drawable/bg_menu_btn"
            android:stateListAnimator="@null"
            android:fontFamily="sans-serif-light"
            android:letterSpacing="0.05"/>

        <View android:layout_width="match_parent" android:layout_height="14dp"/>

        <Button
            android:id="@+id/bouton_highscores"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="@string/text_bouton_highscores"
            android:textSize="16sp"
            android:textColor="@color/calc_btn_number_text"
            android:background="@drawable/bg_menu_btn"
            android:stateListAnimator="@null"
            android:fontFamily="sans-serif-light"
            android:letterSpacing="0.05"/>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

</LinearLayout>
