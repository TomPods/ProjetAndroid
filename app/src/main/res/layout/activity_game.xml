<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/calc_bg">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="8dp">

        <ImageView
            android:id="@+id/bouton_retour"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_arrow_back"
            android:scaleType="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Retour"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/nav_jeu"
            android:textSize="13sp"
            android:textColor="@color/calc_header_text"
            android:gravity="center"
            android:fontFamily="sans-serif-light"
            android:letterSpacing="0.15"/>

        <TextView
            android:id="@+id/language_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌐"
            android:textSize="20sp"
            android:padding="10dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"/>

    </LinearLayout>

    <!-- Stats bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/score_label"
                android:textSize="10sp"
                android:textColor="@color/calc_header_text"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.12"/>

            <TextView
                android:id="@+id/score_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="34sp"
                android:textColor="@color/calc_accent"
                android:fontFamily="sans-serif-light"/>

        </LinearLayout>

        <View
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/lives_label"
                android:textSize="10sp"
                android:textColor="@color/calc_header_text"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.12"/>

            <TextView
                android:id="@+id/lives_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3"
                android:textSize="34sp"
                android:textColor="@color/calc_accent"
                android:fontFamily="sans-serif-light"/>

        </LinearLayout>

    </LinearLayout>

    <!-- Question area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/question_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="?"
            android:textSize="52sp"
            android:textColor="@color/calc_display_text"
            android:fontFamily="sans-serif-light"
            android:gravity="center"/>

    </LinearLayout>

    <!-- Answer field -->
    <EditText
        android:id="@+id/answer_edit"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginStart="40dp"
        android:layout_marginEnd="40dp"
        android:hint="@string/answer_hint"
        android:textColorHint="@color/calc_display_hint"
        android:textColor="@color/calc_display_text"
        android:textSize="28sp"
        android:gravity="center"
        android:fontFamily="sans-serif-light"
        android:inputType="none"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:background="@drawable/bg_answer_field"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:layout_marginBottom="8dp"/>

    <!-- Numpad -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="3"
        android:orientation="vertical"
        android:padding="10dp">

        <!-- Row 1: 7, 8, 9 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <Button
                android:id="@+id/button_7"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:text="7"
                android:textSize="22sp"
                android:textColor="@color/calc_btn_number_text"
                android:background="@drawable/bg_btn_number"
                android:stateListAnimator="@null"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:fontFamily="sans-serif-light"/>

            <Button
                android:id="@+id/button_8"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:text="8"
                android:textSize="22sp"
                android:textColor="@color/calc_btn_number_text"
                android:background="@drawable/bg_btn_number"
                android:stateListAnimator="@null"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:fontFamily="sans-serif-light"/>

            <Button
                android:id="@+id/button_9"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:text="9"
                android:textSize="22sp"
                android:textColor="@color/calc_btn_number_text"
                android:background="@drawable/bg_btn_number"
                android:stateListAnimator="@null"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:fontFamily="sans-serif-light"/>

        </LinearLayout>

        <!-- Row 2: 4, 5, 6 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <Button
                android:id="@+id/button_4"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:text="4"
                android:textSize="22sp"
                android:textColor="@color/calc_btn_number_text"
                android:background="@drawable/bg_btn_number"
                android:stateListAnimator="@null"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:fontFamily="sans-serif-light"/>

            <Button
                android:id="@+id/button_5"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:text="5"
                android:textSize="22sp"
                android:textColor="@color/calc_btn_number_text"
                android:background="@drawable/bg_btn_number"
                android:stateListAnimator="@null"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:fontFamily="sans-serif-light"/>

            <Button
                android:id="@+id/button_6"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:text="6"
                android:textSize="22sp"
                android:textColor="@color/calc_btn_number_text"
                android:background="@drawable/bg_btn_number"
                android:stateListAnimator="@null"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:fontFamily="sans-serif-light"/>

        </LinearLayout>

        <!-- Row 3: 1, 2, 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <Button
                android:id="@+id/button_1"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:text="1"
                android:textSize="22sp"
                android:textColor="@color/calc_btn_number_text"
                android:background="@drawable/bg_btn_number"
                android:stateListAnimator="@null"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:fontFamily="sans-serif-light"/>

            <Button
                android:id="@+id/button_2"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:text="2"
                android:textSize="22sp"
                android:textColor="@color/calc_btn_number_text"
                android:background="@drawable/bg_btn_number"
                android:stateListAnimator="@null"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:fontFamily="sans-serif-light"/>

            <Button
                android:id="@+id/button_3"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:text="3"
                android:textSize="22sp"
                android:textColor="@color/calc_btn_number_text"
                android:background="@drawable/bg_btn_number"
                android:stateListAnimator="@null"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:fontFamily="sans-serif-light"/>

        </LinearLayout>

        <!-- Row 4: 0, ⌫, OK -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <Button
                android:id="@+id/button_0"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:text="0"
                android:textSize="22sp"
                android:textColor="@color/calc_btn_number_text"
                android:background="@drawable/bg_btn_number"
                android:stateListAnimator="@null"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:fontFamily="sans-serif-light"/>

            <Button
                android:id="@+id/button_delete"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:text="⌫"
                android:textSize="20sp"
                android:textColor="@color/calc_btn_function_text"
                android:background="@drawable/bg_btn_function"
                android:stateListAnimator="@null"
                android:minHeight="0dp"
                android:minWidth="0dp"/>

            <Button
                android:id="@+id/button_submit_keyboard"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:text="OK"
                android:textSize="18sp"
                android:textColor="@color/calc_btn_operator_text"
                android:background="@drawable/bg_btn_operator"
                android:stateListAnimator="@null"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:fontFamily="sans-serif-medium"/>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
